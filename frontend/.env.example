# Copy to .env — these are safe to expose to the browser (anon key + RLS).
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Server-only (Vercel functions: /api/chat, /api/mcp). Set these in the Vercel
# project settings — NEVER expose them to the browser (no VITE_ prefix).
ANTHROPIC_API_KEY=sk-ant-...
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY
# SUPABASE_URL is optional; falls back to VITE_SUPABASE_URL.
