# Local development (`vite dev` + `npm run start` for the API server).
#
# In production each team's container is configured by infra/provision-team.sh,
# which writes these same vars into infra/tenants/<slug>/.env — you don't edit
# this file for deployment, only for local dev.

# Browser-safe (anon key + RLS). Served to the SPA at runtime via /config.js.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Server-only (the Hono /api server: /api/chat, /api/classify, /api/config,
# /api/members, /api/mcp). NEVER expose these to the browser (no VITE_ prefix).
ANTHROPIC_API_KEY=sk-ant-...
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY
# Verifies user JWTs + reads the user_role claim for RBAC. Settings → API → JWT secret.
SUPABASE_JWT_SECRET=YOUR-JWT-SECRET
# SUPABASE_URL is optional; falls back to VITE_SUPABASE_URL.

# CRON_SECRET: if set, the in-process daily classify cron presents it as a bearer
# token (and the GET /api/classify path requires it). The provisioner generates one.
CRON_SECRET=

# MCP_TOKEN: leave empty to keep /api/mcp disabled (404). If set, external MCP
# clients must send it as a bearer token. The MCP surface can run read-only SQL,
# so only enable it deliberately.
MCP_TOKEN=
