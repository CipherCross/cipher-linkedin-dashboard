# Copy to .env — these are safe to expose to the browser (anon key + RLS).
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Server-only (Vercel functions: /api/chat, /api/mcp, /api/classify). Set these
# in the Vercel project settings — NEVER expose them to the browser (no VITE_).
ANTHROPIC_API_KEY=sk-ant-...
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY
# SUPABASE_URL is optional; falls back to VITE_SUPABASE_URL.
# CRON_SECRET is optional; if set, the daily /api/classify cron must present it
# as a bearer token (Vercel adds it automatically to scheduled invocations).
CRON_SECRET=
