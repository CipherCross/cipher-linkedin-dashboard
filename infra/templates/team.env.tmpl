# Runtime config + secrets for team {{SLUG}}. Generated by provision-team.sh.
# SECRET — never commit (infra/tenants/**/.env is gitignored).
PORT=8080

# Browser-safe — served to the SPA via /config.js (anon key is RLS-protected).
VITE_SUPABASE_URL={{SUPABASE_URL}}
VITE_SUPABASE_ANON_KEY={{SUPABASE_ANON_KEY}}

# Server-only — used by /api (service role bypasses RLS; JWT secret verifies user
# tokens). Never exposed to the browser.
SUPABASE_URL={{SUPABASE_URL}}
SUPABASE_SERVICE_ROLE_KEY={{SUPABASE_SERVICE_ROLE_KEY}}
SUPABASE_JWT_SECRET={{SUPABASE_JWT_SECRET}}
ANTHROPIC_API_KEY={{ANTHROPIC_API_KEY}}

# Guards the daily classify cron (the in-process scheduler presents it).
CRON_SECRET={{CRON_SECRET}}

# MCP is off unless set. If set, external MCP clients send it as a bearer token.
MCP_TOKEN=
