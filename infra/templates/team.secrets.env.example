# Operator input for provisioning ONE team. Copy to infra/tenants/<slug>.secrets.env,
# fill in, then run: infra/provision-team.sh <slug>
# This file holds secrets — it is gitignored. Delete it after provisioning if you
# prefer not to keep inputs around (the rendered .env is what the container uses).

# Public hostname Caddy will serve (DNS must point at the VPS).
SUBDOMAIN=acme.app.example.com

# From the team's Supabase project → Settings → API.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR-ANON-KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY
SUPABASE_JWT_SECRET=YOUR-JWT-SECRET

# Direct Postgres connection (Settings → Database → Connection string → URI).
# Used to apply migrations and seed the first admin's role.
SUPABASE_DB_URL=postgresql://postgres:PASSWORD@db.YOUR-PROJECT.supabase.co:5432/postgres

# Claude API key for the AI copilot + reply classifier.
ANTHROPIC_API_KEY=sk-ant-...

# First team admin (you create the account; they sign in and can invite others).
ADMIN_EMAIL=admin@acme.com
ADMIN_PASSWORD=change-this-strong-password

# Optional: seed an owner-role account for you (cross-team support access).
OWNER_EMAIL=
OWNER_PASSWORD=

# Optional: auto-configure Auth (disable signups + enable the access-token hook)
# via the Management API. Get a token at https://supabase.com/dashboard/account/tokens.
# If left blank, provision-team.sh prints the manual steps instead.
SUPABASE_PROJECT_REF=
SUPABASE_ACCESS_TOKEN=

# Image tag to run (built from frontend/). Default: latest.
IMAGE_TAG=latest
