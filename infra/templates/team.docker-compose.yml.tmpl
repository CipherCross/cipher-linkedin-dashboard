# Generated by provision-team.sh for team {{SLUG}}. One container, the shared
# image, this team's env file. Joins the proxy's external network so Caddy can
# reach it as {{SLUG}}-app:8080.
name: {{SLUG}}

services:
  app:
    image: linkedin-dashboard:{{IMAGE_TAG}}
    container_name: {{SLUG}}-app
    restart: unless-stopped
    env_file: .env
    networks:
      - dashboard_net

networks:
  dashboard_net:
    external: true
    name: dashboard_net
